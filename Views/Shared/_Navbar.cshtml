<nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom px-4">
    <div class="d-flex align-items-center">
        <button class="btn btn-sm btn-outline-secondary me-3" id="sidebarToggle">
            <i class="bi bi-list fs-5"></i>
        </button>
        <span class="fw-semibold text-muted">@ViewData["Title"]</span>
    </div>

    <div class="ms-auto d-flex align-items-center gap-3">
        <!-- User Info -->
        <div class="d-flex align-items-center gap-2">
            <div class="bg-primary rounded-circle d-flex align-items-center
                        justify-content-center text-white"
                 style="width:35px; height:35px;">
                <i class="bi bi-person-fill"></i>
            </div>
            <div>
                <div class="fw-semibold small">@User.Identity.Name</div>
                <div class="text-muted" style="font-size:11px;">
                    @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                </div>
            </div>
        </div>

        <!-- Logout -->
        <form asp-controller="Auth" asp-action="Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-outline-danger">
                <i class="bi bi-box-arrow-right me-1"></i> Logout
            </button>
        </form>
    </div>
</nav>
