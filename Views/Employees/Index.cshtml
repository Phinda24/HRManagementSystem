@model IEnumerable<HR_Management_System.Models.Entities.Employee>
@{
    ViewData["Title"] = "Employees";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-person-lines-fill text-primary"></i>
            <span class="fw-semibold">All Employees</span>
            <span class="badge bg-primary rounded-pill">@Model.Count()</span>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i> Add Employee
            </a>
        }
    </div>
    <div class="card-body p-0">

        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-people fs-1 d-block mb-3"></i>
                <p>No employees found.</p>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Create" class="btn btn-primary btn-sm">
                        Add First Employee
                    </a>
                }
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Department</th>
                            <th>Position</th>
                            <th>Salary</th>
                            <th>Start Date</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var employee in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="bg-primary rounded-circle
                                                            d-flex align-items-center
                                                            justify-content-center text-white"
                                             style="width:34px; height:34px; font-size:13px;">
                                            @employee.FirstName[0]@employee.LastName[0]
                                        </div>
                                        <span class="fw-semibold small">
                                            @employee.FullName
                                        </span>
                                    </div>
                                </td>
                                <td class="small text-muted">@employee.Email</td>
                                <td class="small">@employee.Department?.Name</td>
                                <td class="small">@employee.Position</td>
                                <td class="small">
                                    R @employee.Salary.ToString("N2")
                                </td>
                                <td class="small">
                                    @employee.StartDate.ToString("dd MMM yyyy")
                                </td>
                                <td>
                                    @if (employee.IsActive)
                                    {
                                        <span class="badge bg-success-subtle
                                                                 text-success rounded-pill px-3">
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle
                                                                 text-danger rounded-pill px-3">
                                            Inactive
                                        </span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-1">
                                        <a asp-action="Details"
                                           asp-route-id="@employee.Id"
                                           class="btn btn-sm btn-outline-secondary"
                                           title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (User.IsInRole("Admin") ||
                                                                        User.IsInRole("Manager"))
                                        {
                                            <a asp-action="Edit"
                                               asp-route-id="@employee.Id"
                                               class="btn btn-sm btn-outline-primary"
                                               title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <form asp-action="Delete"
                                                  asp-route-id="@employee.Id"
                                                  method="post"
                                                  onsubmit="return confirm(
                                                                  'Are you sure you want to
                                                                   remove this employee?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-danger"
                                                        title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
