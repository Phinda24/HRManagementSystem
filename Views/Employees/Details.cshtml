@model HR_Management_System.Models.Entities.Employee
@{
    ViewData["Title"] = "Employee Details";
}

<div class="row">
    <!-- Left Column -->
    <div class="col-md-4">
        <div class="card text-center p-4">
            <div class="bg-primary rounded-circle d-flex align-items-center
                        justify-content-center text-white mx-auto mb-3"
                 style="width:80px; height:80px; font-size:28px;">
                @Model.FirstName[0]@Model.LastName[0]
            </div>
            <h5 class="fw-bold mb-1">@Model.FullName</h5>
            <p class="text-muted small mb-2">@Model.Position</p>
            <span class="badge bg-primary rounded-pill px-3 mb-3">
                @Model.Department?.Name
            </span>

            <hr />

            <div class="text-start small">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <i class="bi bi-envelope text-muted"></i>
                    <span>@Model.Email</span>
                </div>
                <div class="d-flex align-items-center gap-2 mb-2">
                    <i class="bi bi-phone text-muted"></i>
                    <span>@(Model.PhoneNumber ?? "Not provided")</span>
                </div>
                <div class="d-flex align-items-center gap-2 mb-2">
                    <i class="bi bi-calendar text-muted"></i>
                    <span>Started @Model.StartDate.ToString("dd MMM yyyy")</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-cash text-muted"></i>
                    <span>R @Model.Salary.ToString("N2")</span>
                </div>
            </div>

            <hr />

            <div class="d-flex gap-2 mt-2">
                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id"
                       class="btn btn-primary btn-sm flex-fill">
                        <i class="bi bi-pencil me-1"></i> Edit
                    </a>
                }
                <a asp-action="Index"
                   class="btn btn-outline-secondary btn-sm flex-fill">
                    <i class="bi bi-arrow-left me-1"></i> Back
                </a>
            </div>
        </div>
    </div>

    <!-- Right Column - Payslips -->
    <div class="col-md-8">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-cash-stack text-primary"></i>
                <span class="fw-semibold">Payslip History</span>
            </div>
            <div class="card-body p-0">
                @if (Model.Payslips == null || !Model.Payslips.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-receipt fs-2 d-block mb-2"></i>
                        <p class="small">No payslips found for this employee.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Period</th>
                                    <th>Basic Salary</th>
                                    <th>Deductions</th>
                                    <th>Net Salary</th>
                                    <th>Paid On</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var payslip in Model.Payslips
                                    .OrderByDescending(p => p.Year)
                                    .ThenByDescending(p => p.Month))
                                {
                                    <tr>
                                        <td class="small fw-semibold">
                                            @(new DateTime(payslip.Year,
                                                payslip.Month, 1)
                                                .ToString("MMMM yyyy"))
                                        </td>
                                        <td class="small">
                                            R @payslip.BasicSalary.ToString("N2")
                                        </td>
                                        <td class="small text-danger">
                                            - R @payslip.Deductions.ToString("N2")
                                        </td>
                                        <td class="small fw-semibold text-success">
                                            R @payslip.NetSalary.ToString("N2")
                                        </td>
                                        <td class="small text-muted">
                                            @payslip.PaidOn.ToString("dd MMM yyyy")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>