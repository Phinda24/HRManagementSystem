@{
    ViewData["Title"] = "Dashboard";
}

@if (User.IsInRole("Admin"))
{
    <!-- ===== ADMIN DASHBOARD ===== -->
    <div class="row g-3 mb-4">

        <!-- Total Employees -->
        <div class="col-md-3 col-sm-6">
            <div class="stat-card"
                 style="background: linear-gradient(135deg, #1e3a5f, #2d6a9f);">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="small opacity-75 mb-1">Total Employees</div>
                        <div class="fs-3 fw-bold">@ViewBag.TotalEmployees</div>
                    </div>
                    <div class="opacity-50">
                        <i class="bi bi-people-fill fs-2"></i>
                    </div>
                </div>
                <div class="mt-3 small opacity-75">
                    <a asp-controller="Employees" asp-action="Index"
                       class="text-white text-decoration-none">
                        <i class="bi bi-arrow-right me-1"></i>View all employees
                    </a>
                </div>
            </div>
        </div>

        <!-- Total Departments -->
        <div class="col-md-3 col-sm-6">
            <div class="stat-card"
                 style="background: linear-gradient(135deg, #6f42c1, #a855f7);">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="small opacity-75 mb-1">Departments</div>
                        <div class="fs-3 fw-bold">@ViewBag.TotalDepartments</div>
                    </div>
                    <div class="opacity-50">
                        <i class="bi bi-building fs-2"></i>
                    </div>
                </div>
                <div class="mt-3 small opacity-75">
                    <a asp-controller="Departments" asp-action="Index"
                       class="text-white text-decoration-none">
                        <i class="bi bi-arrow-right me-1"></i>View all departments
                    </a>
                </div>
            </div>
        </div>

        <!-- Total Payslips -->
        <div class="col-md-3 col-sm-6">
            <div class="stat-card"
                 style="background: linear-gradient(135deg, #198754, #20c997);">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="small opacity-75 mb-1">Total Payslips</div>
                        <div class="fs-3 fw-bold">@ViewBag.TotalPayslips</div>
                    </div>
                    <div class="opacity-50">
                        <i class="bi bi-receipt fs-2"></i>
                    </div>
                </div>
                <div class="mt-3 small opacity-75">
                    <a asp-controller="Payroll" asp-action="Index"
                       class="text-white text-decoration-none">
                        <i class="bi bi-arrow-right me-1"></i>View payroll
                    </a>
                </div>
            </div>
        </div>

        <!-- Total Payroll -->
        <div class="col-md-3 col-sm-6">
            <div class="stat-card"
                 style="background: linear-gradient(135deg, #dc3545, #fd7e14);">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="small opacity-75 mb-1">Total Payroll</div>
                        <div class="fs-3 fw-bold">
                            R @(ViewBag.TotalPayroll != null
                                                    ? ((decimal)ViewBag.TotalPayroll).ToString("N0") : "0")
                        </div>
                    </div>
                    <div class="opacity-50">
                        <i class="bi bi-cash-stack fs-2"></i>
                    </div>
                </div>
                <div class="mt-3 small opacity-75">
                    <a asp-controller="Payroll" asp-action="Index"
                       class="text-white text-decoration-none">
                        <i class="bi bi-arrow-right me-1"></i>View payroll
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Employees & Quick Actions -->
    <div class="row g-3">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header d-flex justify-content-between
                                align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-clock-history text-primary"></i>
                        <span class="fw-semibold">Recently Added Employees</span>
                    </div>
                    <a asp-controller="Employees" asp-action="Index"
                       class="btn btn-sm btn-outline-primary">View All</a>
                </div>
                <div class="card-body p-0">
                    @if (ViewBag.RecentEmployees != null)
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Name</th>
                                        <th>Position</th>
                                        <th>Department</th>
                                        <th>Joined</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var emp in ViewBag.RecentEmployees)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <div class="bg-primary rounded-circle
                                                                            d-flex align-items-center
                                                                            justify-content-center
                                                                            text-white"
                                                         style="width:32px; height:32px;
                                                                            font-size:12px;">
                                                        @emp.FirstName[0]@emp.LastName[0]
                                                    </div>
                                                    <span class="small fw-semibold">
                                                        @emp.FullName
                                                    </span>
                                                </div>
                                            </td>
                                            <td class="small text-muted">
                                                @emp.Position
                                            </td>
                                            <td class="small">
                                                @emp.Department?.Name
                                            </td>
                                            <td class="small text-muted">
                                                @emp.StartDate.ToString("dd MMM yyyy")
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-people fs-2 d-block mb-2"></i>
                            <p class="small">No employees added yet.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Admin Quick Actions -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class="bi bi-lightning-fill text-primary"></i>
                    <span class="fw-semibold">Quick Actions</span>
                </div>
                <div class="card-body d-flex flex-column gap-2">
                    <a asp-controller="Employees" asp-action="Create"
                       class="btn btn-outline-primary text-start">
                        <i class="bi bi-person-plus-fill me-2"></i>
                        Add New Employee
                    </a>
                    <a asp-controller="Departments" asp-action="Create"
                       class="btn btn-outline-secondary text-start">
                        <i class="bi bi-building-add me-2"></i>
                        Add New Department
                    </a>
                    <a asp-controller="Payroll" asp-action="Generate"
                       class="btn btn-outline-success text-start">
                        <i class="bi bi-receipt me-2"></i>
                        Generate Payslip
                    </a>
                    <a asp-controller="Auth" asp-action="Register"
                       class="btn btn-outline-dark text-start">
                        <i class="bi bi-person-badge me-2"></i>
                        Register New User
                    </a>
                </div>
            </div>

            <!-- Welcome Card -->
            <div class="card mt-3">
                <div class="card-body text-center py-4">
                    <div class="bg-danger rounded-circle d-flex align-items-center
                                    justify-content-center text-white mx-auto mb-3"
                         style="width:56px; height:56px; font-size:22px;">
                        <i class="bi bi-shield-fill"></i>
                    </div>
                    <h6 class="fw-bold mb-1">@User.Identity.Name</h6>
                    <span class="badge bg-danger-subtle text-danger
                                     rounded-pill px-3">
                        Administrator
                    </span>
                    <p class="text-muted small mt-3 mb-0">
                        You have full system access.
                    </p>
                </div>
            </div>
        </div>
    </div>
}
else if (User.IsInRole("Manager"))
    {
    <!-- ===== MANAGER DASHBOARD ===== -->
    <div class="row g-3 mb-4">

        <!-- My Department -->
        <div class="col-md-3 col-sm-6">
            <div class="stat-card"
                 style="background: linear-gradient(135deg, #6f42c1, #a855f7);">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="small opacity-75 mb-1">My Department</div>
                        <div class="fs-5 fw-bold">
                            @(ViewBag.DepartmentName ?? "Not Assigned")
                        </div>
                    </div>
                    <div class="opacity-50">
                        <i class="bi bi-building fs-2"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- My Employees -->
        <div class="col-md-3 col-sm-6">
            <div class="stat-card"
                 style="background: linear-gradient(135deg, #1e3a5f, #2d6a9f);">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="small opacity-75 mb-1">My Employees</div>
                        <div class="fs-3 fw-bold">@ViewBag.TotalEmployees</div>
                    </div>
                    <div class="opacity-50">
                        <i class="bi bi-people-fill fs-2"></i>
                    </div>
                </div>
                <div class="mt-3 small opacity-75">
                    <a asp-controller="Employees" asp-action="Index"
                       class="text-white text-decoration-none">
                        <i class="bi bi-arrow-right me-1"></i>View employees
                    </a>
                </div>
            </div>
        </div>

        <!-- Department Payslips -->
        <div class="col-md-3 col-sm-6">
            <div class="stat-card"
                 style="background: linear-gradient(135deg, #198754, #20c997);">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="small opacity-75 mb-1">Dept Payslips</div>
                        <div class="fs-3 fw-bold">@ViewBag.TotalPayslips</div>
                    </div>
                    <div class="opacity-50">
                        <i class="bi bi-receipt fs-2"></i>
                    </div>
                </div>
                <div class="mt-3 small opacity-75">
                    <a asp-controller="Payroll" asp-action="Index"
                       class="text-white text-decoration-none">
                        <i class="bi bi-arrow-right me-1"></i>View payroll
                    </a>
                </div>
            </div>
        </div>

        <!-- Department Payroll Total -->
        <div class="col-md-3 col-sm-6">
            <div class="stat-card"
                 style="background: linear-gradient(135deg, #dc3545, #fd7e14);">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="small opacity-75 mb-1">Dept Payroll</div>
                        <div class="fs-3 fw-bold">
                            R @(ViewBag.TotalPayroll != null
                                                    ? ((decimal)ViewBag.TotalPayroll).ToString("N0") : "0")
                        </div>
                    </div>
                    <div class="opacity-50">
                        <i class="bi bi-cash-stack fs-2"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Manager Employees Table -->
    <div class="row g-3">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header d-flex justify-content-between
                                align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-people text-primary"></i>
                        <span class="fw-semibold">
                            My Department Employees
                        </span>
                    </div>
                    <a asp-controller="Employees" asp-action="Index"
                       class="btn btn-sm btn-outline-primary">
                        View All
                    </a>
                </div>
                <div class="card-body p-0">
                    @if (ViewBag.RecentEmployees != null)
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Name</th>
                                        <th>Position</th>
                                        <th>Email</th>
                                        <th>Joined</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var emp in
                                                                ViewBag.RecentEmployees)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex
                                                                align-items-center gap-2">
                                                    <div class="bg-primary
                                                                    rounded-circle
                                                                    d-flex align-items-center
                                                                    justify-content-center
                                                                    text-white"
                                                         style="width:32px;
                                                                     height:32px;
                                                                     font-size:12px;">
                                                        @emp.FirstName[0]
                                                        @emp.LastName[0]
                                                    </div>
                                                    <span class="small fw-semibold">
                                                        @emp.FullName
                                                    </span>
                                                </div>
                                            </td>
                                            <td class="small text-muted">
                                                @emp.Position
                                            </td>
                                            <td class="small text-muted">
                                                @emp.Email
                                            </td>
                                            <td class="small text-muted">
                                                @(emp.StartDate
                                                .ToString("dd MMM yyyy"))
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-people fs-2 d-block mb-2"></i>
                            <p class="small">
                                No employees in your department yet.
                            </p>
                        </div>
                    }
            </div>
        </div>
    </div>

    <!-- Manager Quick Actions -->
    <div class="col-md-4">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-lightning-fill text-primary"></i>
                <span class="fw-semibold">Quick Actions</span>
            </div>
            <div class="card-body d-flex flex-column gap-2">
                <a asp-controller="Employees" asp-action="Index"
                   class="btn btn-outline-primary text-start">
                    <i class="bi bi-people me-2"></i>
                    My Employees
                </a>
                <a asp-controller="Payroll" asp-action="Index"
                   class="btn btn-outline-success text-start">
                    <i class="bi bi-receipt me-2"></i>
                    Department Payroll
                </a>
            </div>
        </div>

        <!-- Manager Profile Card -->
        <div class="card mt-3">
            <div class="card-body text-center py-4">
                <div class="d-flex align-items-center
                                justify-content-center text-white
                                mx-auto mb-3 rounded-circle"
                     style="width:56px; height:56px;
                                font-size:22px;
                                background:#6f42c1;">
                    <i class="bi bi-person-badge-fill"></i>
                </div>
                <h6 class="fw-bold mb-1">@User.Identity.Name</h6>
                <span class="badge rounded-pill px-3 mb-2"
                      style="background:#6f42c1; color:white;">
                    Manager
                </span>
                <p class="text-muted small mb-0">
                    Managing:
                    <strong>
                        @(ViewBag.DepartmentName ?? "Not Assigned")
                    </strong>
                </p>
            </div>
        </div>
    </div>
</div>
}
else
{
    <!-- ===== EMPLOYEE DASHBOARD ===== -->
    <div class="row g-3 mb-4">

        <!-- My Payslips Count -->
        <div class="col-md-4 col-sm-6">
            <div class="stat-card"
                 style="background: linear-gradient(135deg, #198754, #20c997);">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="small opacity-75 mb-1">My Payslips</div>
                        <div class="fs-3 fw-bold">
                            @(ViewBag.MyPayslipCount ?? 0)
                        </div>
                    </div>
                    <div class="opacity-50">
                        <i class="bi bi-receipt fs-2"></i>
                    </div>
                </div>
                <div class="mt-3 small opacity-75">
                    <a asp-controller="Payroll" asp-action="Index"
                       class="text-white text-decoration-none">
                        <i class="bi bi-arrow-right me-1"></i>View my payslips
                    </a>
                </div>
            </div>
        </div>

        <!-- Latest Net Salary -->
        <div class="col-md-4 col-sm-6">
            <div class="stat-card"
                 style="background: linear-gradient(135deg, #1e3a5f, #2d6a9f);">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="small opacity-75 mb-1">Latest Net Salary</div>
                        <div class="fs-3 fw-bold">
                            R @(ViewBag.LatestNetSalary != null
                                                    ? ((decimal)ViewBag.LatestNetSalary).ToString("N0") : "0")
                    </div>
                </div>
                <div class="opacity-50">
                    <i class="bi bi-cash-coin fs-2"></i>
                </div>
            </div>
            <div class="mt-3 small opacity-75">
                <i class="bi bi-info-circle me-1"></i>
                Most recent payslip
            </div>
        </div>
    </div>

        <!-- Department -->
        <div class="col-md-4 col-sm-6">
            <div class="stat-card"
                 style="background: linear-gradient(135deg, #6f42c1, #a855f7);">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <div class="small opacity-75 mb-1">My Department</div>
                        <div class="fs-4 fw-bold">
                            @(ViewBag.MyDepartment ?? "Not Assigned")
                        </div>
                    </div>
                    <div class="opacity-50">
                        <i class="bi bi-building fs-2"></i>
                    </div>
                </div>
                <div class="mt-3 small opacity-75">
                    <i class="bi bi-geo-alt me-1"></i>
                    Current department
                </div>
            </div>
        </div>
    </div>

    <!-- Employee Content -->
    <div class="row g-3">

        <!-- My Recent Payslips -->
        <div class="col-md-8">
            <div class="card">
                <div class="card-header d-flex justify-content-between
                        align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-receipt text-primary"></i>
                        <span class="fw-semibold">My Recent Payslips</span>
                    </div>
                    <a asp-controller="Payroll" asp-action="Index"
                       class="btn btn-sm btn-outline-primary">
                        View All
                    </a>
                </div>
                <div class="card-body p-0">
                @if (ViewBag.MyRecentPayslips != null)
                    {
                        var payslips = ViewBag.MyRecentPayslips
                        as IEnumerable<HR_Management_System.Models.Entities.Payslip>;

                        if (payslips != null && payslips.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Period</th>
                                            <th>Basic Salary</th>
                                            <th>Deductions</th>
                                            <th>Net Salary</th>
                                            <th>Paid On</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var p in payslips)
                                        {
                                            <tr>
                                                <td class="small fw-semibold">
                                                    @(new DateTime(p.Year,
                                                                                        p.Month, 1)
                                                                                        .ToString("MMMM yyyy"))
                                </td>
                                <td class="small">
                                    R @p.BasicSalary.ToString("N2")
                                </td>
                                <td class="small text-danger">
                                    - R @p.Deductions.ToString("N2")
                                </td>
                                <td class="small fw-bold text-success">
                                    R @p.NetSalary.ToString("N2")
                                </td>
                                <td class="small text-muted">
                                    @p.PaidOn.ToString("dd MMM yyyy")
                                </td>
                            </tr>
                                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-4 text-muted">
                                <i class="bi bi-receipt fs-2 d-block mb-2"></i>
                                <p class="small">No payslips found yet.</p>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-receipt fs-2 d-block mb-2"></i>
                            <p class="small">No payslips found yet.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Employee Profile Card -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center py-4">
                    <div class="bg-success rounded-circle d-flex align-items-center
                                    justify-content-center text-white mx-auto mb-3"
                         style="width:64px; height:64px; font-size:26px;">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <h6 class="fw-bold mb-1">@User.Identity.Name</h6>
                    <span class="badge bg-success-subtle text-success
                                     rounded-pill px-3 mb-3">
                        Employee
                    </span>

                    <hr />

                    <div class="text-start small">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <i class="bi bi-envelope text-muted"></i>
                            <span>
                                @User.FindFirst(
                                System.Security.Claims.ClaimTypes.Email)?.Value
                        </span>
                    </div>
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-building text-muted"></i>
                        <span>@(ViewBag.MyDepartment ?? "Not Assigned")</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-briefcase text-muted"></i>
                        <span>@(ViewBag.MyPosition ?? "Not Assigned")</span>
                    </div>
                </div>
            </div>
        </div>

            <!-- Quick Links -->
            <div class="card mt-3">
                <div class="card-header d-flex align-items-center gap-2">
                    <i class="bi bi-lightning-fill text-primary"></i>
                    <span class="fw-semibold">Quick Links</span>
                </div>
                <div class="card-body d-flex flex-column gap-2">
                    <a asp-controller="Payroll" asp-action="Index"
                       class="btn btn-outline-success text-start">
                        <i class="bi bi-receipt me-2"></i>
                        My Payslips
                    </a>
                </div>
            </div>
        </div>
    </div>
}