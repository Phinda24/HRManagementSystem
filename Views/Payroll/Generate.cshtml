@model HR_Management_System.Models.ViewModels.Payroll.GeneratePayslipViewModel
@{
    ViewData["Title"] = "Generate Payslip";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-receipt text-primary"></i>
                <span class="fw-semibold">Generate New Payslip</span>
            </div>
            <div class="card-body p-4">

                <form asp-action="Generate" method="post" id="payslipForm">
                    @Html.AntiForgeryToken()

                    <!-- Employee -->
                    <div class="mb-3">
                        <label asp-for="EmployeeId"
                               class="form-label fw-semibold small"></label>
                        <select asp-for="EmployeeId"
                                asp-items="Model.Employees"
                                class="form-select">
                            <option value="">-- Select Employee --</option>
                        </select>
                        <span asp-validation-for="EmployeeId"
                              class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <!-- Month -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="Month"
                                   class="form-label fw-semibold small"></label>
                            <select asp-for="Month" class="form-select">
                                <option value="">-- Select Month --</option>
                                @for (int m = 1; m <= 12; m++)
                                {
                                    <option value="@m"
                                            selected="@(m == Model.Month)">
                                        @(new DateTime(2000, m, 1).ToString("MMMM"))
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="Month"
                                  class="text-danger small"></span>
                        </div>

                        <!-- Year -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="Year"
                                   class="form-label fw-semibold small"></label>
                            <select asp-for="Year" class="form-select">
                                <option value="">-- Select Year --</option>
                                @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--)
                                {
                                    <option value="@y"
                                            selected="@(y == Model.Year)">
                                        @y
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="Year"
                                  class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <!-- Basic Salary -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="BasicSalary"
                                   class="form-label fw-semibold small"></label>
                            <div class="input-group">
                                <span class="input-group-text">R</span>
                                <input asp-for="BasicSalary"
                                       class="form-control"
                                       placeholder="0.00"
                                       id="basicSalary"
                                       oninput="calculateNet()" />
                            </div>
                            <span asp-validation-for="BasicSalary"
                                  class="text-danger small"></span>
                        </div>

                        <!-- Deductions -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="Deductions"
                                   class="form-label fw-semibold small"></label>
                            <div class="input-group">
                                <span class="input-group-text">R</span>
                                <input asp-for="Deductions"
                                       class="form-control"
                                       placeholder="0.00"
                                       id="deductions"
                                       oninput="calculateNet()" />
                            </div>
                            <span asp-validation-for="Deductions"
                                  class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Net Salary Preview -->
                    <div class="alert alert-success d-flex justify-content-between
                                align-items-center mb-4">
                        <span class="fw-semibold">
                            <i class="bi bi-calculator me-2"></i>Net Salary
                        </span>
                        <span class="fw-bold fs-5" id="netSalaryPreview">R 0.00</span>
                    </div>

                    <!-- Buttons -->
                    <div class="d-flex gap-2">
                        <button type="submit"
                                class="btn btn-primary flex-fill fw-semibold">
                            <i class="bi bi-receipt me-2"></i> Generate Payslip
                        </button>
                        <a asp-action="Index"
                           class="btn btn-outline-secondary flex-fill">
                            Cancel
                        </a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function calculateNet() {
            const basic = parseFloat(
                document.getElementById('basicSalary').value) || 0;
            const deductions = parseFloat(
                document.getElementById('deductions').value) || 0;
            const net = basic - deductions;
            document.getElementById('netSalaryPreview').textContent =
                'R ' + net.toLocaleString('en-ZA', {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                });
        }
    </script>
}
